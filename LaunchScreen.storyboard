<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.Storyboard" version="3.0"
          toolsVersion="18122" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none"
          useAutolayout="YES" launchScreen="YES" useTraitCollections="YES">
  <scenes>
    <!--View Controller-->
    <scene sceneID="launch-scene">
      <objects>
        <viewController id="LaunchViewController" sceneMemberID="viewController">
          <view key="view" contentMode="scaleToFill" id="LaunchView">
            <rect key="frame" x="0.0" y="0.0" width="375" height="667"/>
            <color key="backgroundColor" white="1" alpha="1" colorSpace="calibratedWhite"/>
          </view>
        </viewController>
        <placeholder placeholderIdentifier="IBFirstResponder" id="firstResponder" userLabel="First Responder"/>
      </objects>
    </scene>
  </scenes>
</document>
